# Application
APP_NAME=Excel Importer
APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Local MySQL Database (Docker)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=excel_importer_db
DB_USERNAME=sail
DB_PASSWORD=password

# Remote MSSQL Server Configuration (User inputs in UI, defaults here for testing)
MSSQL_SERVER=localhost
MSSQL_DATABASE=tempdb
MSSQL_TRUSTED_CONNECTION=yes
MSSQL_PORT=1433

# File Upload Limits
FILE_UPLOAD_MAX_FILESIZE=5M
MAX_FILE_SIZE_BYTES=5242880

# Security
SECRET_KEY_BASE=
