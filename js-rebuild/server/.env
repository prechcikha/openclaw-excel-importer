# Server Configuration
PORT=3000
NODE_ENV=development

# Local MySQL Database (for storing connections, mappings, import history)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=P@ssw0rd
DB_NAME=excel_importer_db

# Remote MSSQL Server Configuration (defaults - can be overridden via UI)
MSSQL_SERVER=localhost
MSSQL_DATABASE=tempdb
MSSQL_TRUSTED_CONNECTION=yes
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=

# File Upload Limits
MAX_FILE_SIZE=52428800  # 50MB in bytes
TIMEOUT_MS=120000       # 2 minutes timeout
